---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ThemeSwitcher from '../components/ThemeSwitcher';
import ColdBoot from '../components/ColdBoot';
import HeroSection from '../components/HeroSection.astro';
import DataSpine from '../components/DataSpine';
import ProjectDeck from '../components/ProjectDeck';
import Constellation from '../components/Constellation';
import AboutSection from '../components/AboutSection.astro';
import ContactSection from '../components/ContactSection.astro';
import SiteFooter from '../components/SiteFooter.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const spineProjects = projects.map((p) => ({
  title: p.data.title,
  role: p.data.role,
  summary: p.data.summary,
  stack: p.data.stack,
}));
const deckProjects = projects.map((p) => ({
  title: p.data.title,
  status: p.data.status,
  year: p.data.year,
  stack: p.data.stack,
  summary: p.data.summary,
}));
---
<Base>
  <ColdBoot client:load />
  <Nav />

  <HeroSection />

  <DataSpine client:visible projects={spineProjects} />

  <section class="deck-sec" id="projects">
    <div class="wrap">
      <div class="reveal">
        <div class="eyebrow">Selected Projects</div>
        <h2 class="sec-title">Things that shipped — and things in flight.</h2>
      </div>
      <ProjectDeck client:visible projects={deckProjects} />
    </div>
  </section>

  <section class="skills-sec" id="skills">
    <div class="wrap">
      <div class="reveal">
        <div class="eyebrow">The Stack, Alive</div>
        <h2 class="sec-title">A living graph of how I work.</h2>
      </div>
      <Constellation client:visible />
    </div>
  </section>

  <AboutSection />
  <ContactSection />
  <SiteFooter />

  <ThemeSwitcher client:idle />
</Base>
